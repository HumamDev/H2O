{
  "manifest_version": 3,
  "name": "H2O Dev Loader (Lean, Unpacked)",
  "version": "1.2.0",
  "description": "Dev-only local loader for H2O scripts on chatgpt.com (lean mode, no popup toggles).",
  "permissions": [],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "H2O Dev Loader (Lean)",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    }
  },
  "background": {
    "service_worker": "bg.js"
  },
  "host_permissions": [
    "http://127.0.0.1:5500/*",
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "loader.js"
      ],
      "run_at": "document_start"
    }
  ]
}

{
  "manifest_version": 3,
  "name": "H2O Dev Controls (Unpacked)",
  "version": "1.2.0",
  "description": "Dev-only local loader with per-script toggles for H2O scripts on chatgpt.com.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "H2O Dev Controls",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "bg.js"
  },
  "host_permissions": [
    "http://127.0.0.1:5500/*",
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "loader.js"
      ],
      "run_at": "document_start"
    }
  ]
}

# macOS
.DS_Store

# Node
node_modules/

# Archive snapshots and state outputs
archive/**
archive/.gitkeep

# Generated unpacked chrome/firefox extension outputs.
# Canonical location is apps/extensions/<host>/<browser>/<variant>/ (post-4C-B).
# Phase 8E-3 (2026-05-19) removed the legacy build/chrome-ext-* symlink bridge;
# the build/** rule is kept as a safety net in case any future tool inadvertently
# writes a build/ folder (manifest keys make Chrome IDs path-independent, but
# the rule prevents accidental commits of generated artifacts).
# Phase 8G-5 (2026-05-19) added claude/chrome rule for the first new-host stub;
# the README.md placeholders established in Phase 7D stay tracked via the
# explicit !README.md exception per host/browser combination.
build/**
apps/extensions/chatgpt/chrome/**
apps/extensions/chatgpt/firefox/**
!apps/extensions/chatgpt/firefox/README.md
apps/extensions/claude/chrome/**
!apps/extensions/claude/chrome/README.md
apps/extensions/gemini/chrome/**
!apps/extensions/gemini/chrome/README.md

# Generated dev-server content. Phase 5B (2026-05-17) absorbed the sibling
# h2o-dev-server/ into apps/dev-server/. The Python source (serve.py) is
# tracked; the regenerated alias farm and dev_output/proxy/_paste-pack.ext.txt
# are produced by tools/loader/make-aliases.mjs and
# tools/loader/make-ext-proxy-pack.mjs at every dev build.
apps/dev-server/alias/**
apps/dev-server/dev_output/**

# Python bytecode cache (created by python3 -m py_compile / running scripts).
__pycache__/
*.pyc

# Generated reports and ledgers (keep placeholders)
meta/reports/**
meta/reports/.gitkeep
meta/ledger/**
meta/ledger/.gitkeep
meta/notes/.gitkeep
meta/README.md

# Local-only commit message input
meta/notes/COMMIT_MESSAGE.txt
meta/notes/COMMIT_QUEUE.txt

# Local assistant workflow and scratch material (not for repo)
.claude/
s-files/
CLAUDE.md
"CLAUDE 2.md"
/assets/
references/
tasks-manual-*.md
git-status.txt
staged.txt
unstaged.txt

# Local-only test/scratch config files
config/__codex-*.json
config/userscript-headers.html
config/userscript-headers.tsv
config/dev-order.txt
config/dev-order.json
config/scripts-list.tsv
config/local/identity-provider.local.json
/identity-provider.local.json

# Local-only editor/workspace notes
meta/notes/vscode-keybindings.json
.vscode/*.local.json

# macOS Finder duplicate files (created by Cmd+D / "Duplicate")
* 2.js
* 2.mjs
* 2.css
* 2.html
* 2.json
* 2.md

AGENTS.md

# Mobile app generated artifacts (defense in depth; nested .gitignore is the primary)
apps/**/node_modules/
apps/**/.expo/
apps/**/dist/
apps/**/web-build/
apps/**/expo-env.d.ts
apps/**/*.tsbuildinfo
apps/**/.env*.local
apps/**/ios/Pods/
apps/**/ios/build/
apps/**/ios/.xcode.env.local
apps/**/ios/**/xcuserdata/
apps/**/ios/**/*.xcuserstate
apps/**/android/build/
apps/**/android/.gradle/
apps/**/android/app/build/

# Local CLI caches, scratch, plans, and one-off build artifacts
/supabase/.temp/
/tmp/
# Phase 7D (2026-05-18): track only artifacts/README.md as a placeholder
# documenting future-use; keep everything else under artifacts/ ignored
# (existing local zip archives, etc.).
/artifacts/*
!/artifacts/README.md
/plans/

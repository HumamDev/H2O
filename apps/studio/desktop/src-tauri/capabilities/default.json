{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "default",
  "description": "Default capability for the H2O Studio main window. M1 grants the minimum needed to boot Studio's UI and open external URLs via tauri-plugin-shell. M2d-1a adds read-only filesystem access (download folder + home) for manual Browser Studio bundle sync. R2A-1 adds narrowly scoped write access for the Desktop latest sync bundle. F4 adds scoped producer-side peer mirror writes under devices/.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:allow-open",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$DOWNLOAD/**" },
        { "path": "$HOME/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$DOWNLOAD/**" },
        { "path": "$HOME/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/H2O Studio Sync" },
        { "path": "$HOME/H2O Studio Sync/devices" },
        { "path": "$HOME/H2O Studio Sync/devices/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/H2O Studio Sync/.latest.json.tmp" },
        { "path": "$HOME/H2O Studio Sync/latest.json" },
        { "path": "$HOME/H2O Studio Sync/devices/**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/H2O Studio Sync/.latest.json.tmp" },
        { "path": "$HOME/H2O Studio Sync/latest.json" },
        { "path": "$HOME/H2O Studio Sync/devices/**" }
      ]
    }
  ]
}

{
  "name": "h2o-cp-source",
  "private": true,
  "scripts": {
    "dev:all": "node tools/dev/dev-all.mjs",
    "dev:rebuild": "node tools/dev/dev-rebuild.mjs",
    "dev:check": "node tools/dev/dev-check.mjs",
    "commit:auto": "H2O_META_DIR=\"$PWD/../meta\" node tools/git/commit-auto.mjs",
    "commit:auto:dry": "H2O_META_DIR=\"$PWD/../meta\" node tools/git/commit-auto.mjs --dry-run",
    "commit:auto:msg": "H2O_META_DIR=\"$PWD/../meta\" node tools/git/commit-auto.mjs --message-file \"$PWD/../meta/notes/COMMIT_MESSAGE.txt\"",
    "commit:auto:msg:dry": "H2O_META_DIR=\"$PWD/../meta\" node tools/git/commit-auto.mjs --message-file \"$PWD/../meta/notes/COMMIT_MESSAGE.txt\" --dry-run",
    "commit:release": "H2O_META_DIR=\"$PWD/../meta\" H2O_CHANGELOGS_DIR=\"$PWD/../changelogs\" node tools/release/release-commit-helper.mjs",
    "edit:log": "H2O_META_DIR=\"$PWD/../meta\" node tools/versioning/edit-log.mjs",
    "rev:dry": "H2O_META_DIR=\"$PWD/../meta\" node tools/versioning/rev-stamp.mjs --dry-run",
    "rev:stamp": "H2O_META_DIR=\"$PWD/../meta\" node tools/versioning/rev-stamp.mjs --with-build --log-edit",
    "rev:stamp:file": "H2O_META_DIR=\"$PWD/../meta\" node tools/versioning/rev-stamp.mjs --with-build --files",
    "rev:save": "H2O_META_DIR=\"$PWD/../meta\" node tools/versioning/rev-stamp.mjs --with-build --files",
    "hooks:install": "node tools/git/install-hooks.mjs",
    "ship:commit": "H2O_META_DIR=\"$PWD/../meta\" H2O_CHANGELOGS_DIR=\"$PWD/../changelogs\" node tools/release/ship-commit.mjs",
    "archive:snap": "H2O_ARCHIVE_DIR=\"$PWD/../archive\" node tools/archive/archive-snapshot.mjs \"$PWD\"",
    "archive:one": "H2O_ARCHIVE_DIR=\"$PWD/../archive\" node tools/archive/archive-one.mjs",
    "archive:pick": "H2O_ARCHIVE_DIR=\"$PWD/../archive\" node tools/archive/archive-one.mjs --pick",
    "archive:recent": "H2O_ARCHIVE_DIR=\"$PWD/../archive\" node tools/archive/archive-one.mjs --recent",
    "versions:build": "H2O_META_DIR=\"$PWD/../meta\" node tools/versioning/versions-dashboard.mjs",
    "dashboard:build": "npm run versions:build",
    "dashboard:watch": "H2O_META_DIR=\"$PWD/../meta\" node tools/versioning/dashboard-watch.mjs",
    "dashboard:watch:fast": "H2O_META_DIR=\"$PWD/../meta\" node tools/versioning/dashboard-watch.mjs --debounce-ms 5000",
    "release": "H2O_META_DIR=\"$PWD/../meta\" H2O_CHANGELOGS_DIR=\"$PWD/../changelogs\" node tools/release/release.mjs",
    "release:dry": "H2O_META_DIR=\"$PWD/../meta\" H2O_CHANGELOGS_DIR=\"$PWD/../changelogs\" node tools/release/release.mjs --dry-run",
    "ship": "npm run release && H2O_ARCHIVE_DIR=\"$PWD/../archive\" node tools/archive/archive-snapshot.mjs \"$PWD\"",
    "ship:dry": "npm run release:dry",
    "gate:library": "node tools/validation/sync/run-f16-production-release-gate.mjs",
    "audit:secrets": "node tools/validation/release/validate-f17-secret-config-audit.mjs",
    "validate:build": "node tools/validation/release/validate-f17-build-package.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "semver": "^7.6.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "expo-modules-core": "^55.0.25",
    "react-native-worklets": "0.7.4",
    "sharp": "^0.34.5"
  },
  "workspaces": [
    "apps/studio/desktop",
    "apps/studio/mobile",
    "apps/site",
    "packages/*"
  ]
}

{
  "name": "h2o-source",
  "private": true,
  "scripts": {
    "dev:all": "node tools/dev/dev-all.mjs",
    "dev:rebuild": "node tools/dev/dev-rebuild.mjs",
    "dev:check": "node tools/dev/dev-check.mjs",
    "commit:auto": "node tools/git/commit-auto.mjs",
    "commit:auto:dry": "node tools/git/commit-auto.mjs --dry-run",
    "commit:auto:msg": "node tools/git/commit-auto.mjs --message-file meta/notes/COMMIT_MESSAGE.txt",
    "commit:auto:msg:dry": "node tools/git/commit-auto.mjs --message-file meta/notes/COMMIT_MESSAGE.txt --dry-run",
    "commit:release": "node tools/release/release-commit-helper.mjs",
    "edit:log": "node tools/versioning/edit-log.mjs",
    "rev:dry": "node tools/versioning/rev-stamp.mjs --dry-run",
    "rev:stamp": "node tools/versioning/rev-stamp.mjs --with-build --log-edit",
    "rev:stamp:file": "node tools/versioning/rev-stamp.mjs --with-build --files",
    "rev:save": "node tools/versioning/rev-stamp.mjs --with-build --files",
    "hooks:install": "node tools/git/install-hooks.mjs",
    "ship:commit": "node tools/release/ship-commit.mjs",
    "archive:snap": "node tools/archive/archive-snapshot.mjs \"$PWD\"",
    "archive:one": "node tools/archive/archive-one.mjs",
    "archive:pick": "node tools/archive/archive-one.mjs --pick",
    "archive:recent": "node tools/archive/archive-one.mjs --recent",
    "versions:build": "node tools/versioning/versions-dashboard.mjs",
    "dashboard:build": "npm run versions:build",
    "dashboard:watch": "node tools/versioning/dashboard-watch.mjs",
    "dashboard:watch:fast": "node tools/versioning/dashboard-watch.mjs --debounce-ms 5000",
    "release": "node tools/release/release.mjs",
    "release:dry": "node tools/release/release.mjs --dry-run",
    "ship": "npm run release && node tools/archive/archive-snapshot.mjs \"$PWD\"",
    "ship:dry": "npm run release:dry"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "semver": "^7.6.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "sharp": "^0.34.5"
  }
}
